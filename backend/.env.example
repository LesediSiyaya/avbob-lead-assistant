# ============================================================
#  AVBOB Lead Assistant — .env.example
#  Copy to .env and fill in your values
#  NEVER commit .env to Git
# ============================================================

# ── AI Provider (choose one) ───────────────────────────────────
# Option A: OpenAI (recommended — fastest)
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o-mini          # cheapest + fast enough

# Option B: Local Ollama (free, runs offline)
# Set USE_OLLAMA=true and make sure Ollama is running
USE_OLLAMA=false
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3               # or mistral, phi3, etc.

# ── Database ───────────────────────────────────────────────────
DB_PATH=avbob_leads.db            # relative path, created automatically

# ── Facebook Graph API Webhook ─────────────────────────────────
# Set these in your Replit deployment Secrets after creating a Facebook App
FB_VERIFY_TOKEN=pick_any_random_string   # must match what you enter in Facebook webhook settings
FB_PAGE_ACCESS_TOKEN=                    # Page Access Token from Facebook Developer App

# ── Server ─────────────────────────────────────────────────────
PORT=8000
HOST=0.0.0.0                      # use 127.0.0.1 for local-only
